{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "FraudDetection": {
    "LargeTransactionThreshold": 10000,
    "RapidDebitThreshold": 3000,
    "RapidTransactionCount": 3,
    "RapidTransactionWindowMinutes": 60,
    "FlaggedKeywords": [ "casino", "crypto", "anonymous", "offshore" ]
  }
}
